{
  "name": "acheron",
  "version": "1.0.0",
  "description": "Native terminal user interface workbench for local AI model orchestration",
  "main": "dist/cli.js",
  "bin": {
    "acheron": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "npx node_modules/typescript/bin/tsc",
    "start": "npm run build && node dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "ink",
    "ollama",
    "tui",
    "ai-agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
